# Flipper Environment Configuration
# Copy this file to .env and fill in your actual values

# ═══ FIRECRAWL ═══════════════════════════════════════════════════════════════
# API key (or "local" for self-hosted Firecrawl without auth)
FIRECRAWL_API_KEY=local

# Self-hosted Firecrawl URL (docker-compose переопределяет через PARSER_FIRECRAWL_BASE_URL)
FIRECRAWL_BASE_URL=http://flippercrawl-api-1:3002
# Если Firecrawl в той же Docker-сети firecrawl_backend:
# PARSER_FIRECRAWL_BASE_URL=http://flippercrawl-api-1:3002

# ═══ GOOGLE SHEETS ═══════════════════════════════════════════════════════════
# Spreadsheet ID (из URL: docs.google.com/spreadsheets/d/{ID})
SPREADSHEET_ID=your-spreadsheet-id

# Path to Google Service Account credentials JSON
CREDENTIALS_PATH=/app/credentials.json

# ═══ DATABASE (PostgreSQL) ═══════════════════════════════════════════════════
# Пароль для PostgreSQL user "flipper" (используется в docker-compose)
POSTGRES_PASSWORD=flipper_secret

# Override только если PostgreSQL вне docker-compose:
# DATABASE_URL=postgresql+asyncpg://flipper:flipper_secret@app_postgres:5432/flipper

# ═══ TELEGRAM ════════════════════════════════════════════════════════════════
# Бот для уведомлений (Signal, Продано, Cookie error)
TG_BOT_TOKEN=your-telegram-bot-token
TG_CHAT_ID=your-telegram-chat-id

# ═══ COOKIE MANAGER ═════════════════════════════════════════════════════════
# Внутренний URL (контейнер → контейнер)
COOKIE_MANAGER_URL=http://cookie_manager:8000
COOKIE_CHECK_INTERVAL=1800

# Публичный URL NoVNC (для ссылки в Telegram при "Куки слетели")
# Подставьте IP вашего сервера: curl -4 ifconfig.me
NOVNC_PUBLIC_URL=http://YOUR_SERVER_IP:8080/vnc.html

# ═══ PARSER ══════════════════════════════════════════════════════════════════
# Параллельных воркеров (зависит от мощности Firecrawl)
PARSER_CONCURRENCY=50

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ═══ PROXIES ═════════════════════════════════════════════════════════════════
# Резидентские прокси для парсинга списков Cian — из файла data/proxies.txt
# Формат файла: host:port:user:pass (по одному на строку)
# Если файл пустой или отсутствует — прямой запрос без прокси

# HTML → Markdown сервис (опционально)
HTML_TO_MARKDOWN_URL=http://html_to_markdown:8080
