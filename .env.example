# Flipper Environment Configuration
# Copy this file to .env and fill in your actual values

# ═══ FIRECRAWL API ═══════════════════════════════════════════════════════════
# Get API key from: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here

# ═══ GOOGLE SHEETS ═══════════════════════════════════════════════════════════
# Google Sheets spreadsheet ID (from URL: docs.google.com/spreadsheets/d/{ID})
SPREADSHEET_ID=1your-spreadsheet-id-here

# Path to Google Service Account credentials JSON file
# Download from: Google Cloud Console → Service Account → Create Key
CREDENTIALS_PATH=/app/credentials.json

# ═══ PROXY & RATE LIMITING ═══════════════════════════════════════════════════
# Mobile proxy settings for IP rotation
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# Endpoint to change IP address
# Example: http://proxy.local:8080/changeip
CHANGE_IP_URL=http://proxy.example.com:8080/changeip

# Full proxy URL for HTTP requests
# Format: http://username:password@proxy:port
HTTP_PROXY=http://your_proxy_username:your_proxy_password@proxy.example.com:8080

# ═══ COOKIE MANAGER ═════════════════════════════════════════════════════════
# Interval between cookie validity checks (seconds)
# 1800 = 30 minutes
COOKIE_CHECK_INTERVAL=1800

# Path where cookies.json is stored
# In Docker: /app/cookies.json
COOKIES_FILE=/app/cookies.json

# ═══ DATABASE (PostgreSQL) ════════════════════════════════════════════════════
# Password for the flipper PostgreSQL user (used in docker-compose)
POSTGRES_PASSWORD=flipper_secret

# Connection URL (override only if running Postgres outside docker-compose)
# DATABASE_URL=postgresql+asyncpg://flipper:flipper_secret@app_postgres:5432/flipper

# ═══ PARSER SETTINGS ═════════════════════════════════════════════════════════
# Number of concurrent workers for parsing (parallel Firecrawl requests)
# Depends on your Firecrawl instance capacity
PARSER_CONCURRENCY=50

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ═══ NOTIFICATIONS (OPTIONAL) ════════════════════════════════════════════════
# Telegram bot token
# Get from: @BotFather on Telegram
TG_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID where to send notifications
# Get by: @userinfobot on Telegram
TG_CHAT_ID=your-telegram-chat-id-here

# ═══ COOKIE MANAGER - NOVNC ══════════════════════════════════════════════════
# NoVNC interface URL (for Telegram notification)
# Local: http://localhost:8080/vnc.html
# Production: https://your-domain.com:8080/vnc.html
NOVNC_URL=http://localhost:8080/vnc.html
